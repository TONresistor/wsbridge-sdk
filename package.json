{
  "name": "wsbridge-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the TON WebSocket JSON-RPC bridge",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.mts", "default": "./dist/index.mjs" },
      "require": { "types": "./dist/index.d.ts", "default": "./dist/index.cjs" }
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/TONresistor/wsbridge-sdk"
  },
  "license": "MIT",
  "keywords": ["ton", "websocket", "json-rpc", "blockchain", "sdk"],
  "peerDependencies": { "ws": ">=8.0.0" },
  "peerDependenciesMeta": { "ws": { "optional": true } },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsup": "^8.0.0",
    "ws": "^8.0.0",
    "@types/ws": "^8.0.0",
    "vitest": "^4.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run type-check",
    "lint": "tsc --noEmit"
  },
  "engines": { "node": ">=18" }
}
